#!/bin/bash

# =============================================
# ЛАБОРАТОРНАЯ РАБОТА №8 - ЗАПУСК ОТЧЁТОВ
# =============================================

show_help() {
    echo "============================================="
    echo "  ЛАБОРАТОРНАЯ РАБОТА №8 - ВУЗ"
    echo "============================================="
    echo ""
    echo "Использование:"
    echo "  ./PYTHON task1 [группа] [дисциплина]"
    echo "  ./PYTHON task2 [группа]"
    echo "  ./PYTHON task3 [--save] [--force]"
    echo "  ./PYTHON task4 [группа] [--save] [--force]"
    echo "  ./PYTHON save-all [--force]"
    echo "  ./PYTHON all"
    echo ""
    echo "Примеры:"
    echo "  ./PYTHON task1"
    echo "  ./PYTHON task1 ИНФ-101"
    echo "  ./PYTHON task2"
    echo "  ./PYTHON task2 ИНФ"
    echo "  ./PYTHON task3"
    echo "  ./PYTHON task3 --save"
    echo "  ./PYTHON task4"
    echo "  ./PYTHON task4 ИНФ --save"
    echo "  ./PYTHON save-all"
    echo "  ./PYTHON save-all --force"
    echo "  ./PYTHON all"
}

case "$1" in
    task1)
        if [ -z "$2" ]; then
            python3 lab8_report_fixed.py task1
        elif [ -z "$3" ]; then
            python3 lab8_report_fixed.py task1 "$2"
        else
            python3 lab8_report_fixed.py task1 "$2" "$3"
        fi
        ;;
    task2)
        if [ -z "$2" ]; then
            python3 lab8_report_fixed.py task2
        else
            python3 lab8_report_fixed.py task2 "$2"
        fi
        ;;
    task3)
        if [[ "$2" == "--save" ]] || [[ "$2" == "--force" ]]; then
            python3 lab8_chart.py task3 "$2"
        elif [[ "$3" == "--save" ]] || [[ "$3" == "--force" ]]; then
            python3 lab8_chart.py task3 "$2" "$3"
        else
            python3 lab8_chart.py task3
        fi
        ;;
    task4)
        if [[ "$2" == "--save" ]] || [[ "$2" == "--force" ]]; then
            python3 lab8_chart.py task4 "$2"
        elif [[ "$3" == "--save" ]] || [[ "$3" == "--force" ]]; then
            python3 lab8_chart.py task4 "$2" "$3"
        elif [ -z "$2" ]; then
            python3 lab8_chart.py task4
        else
            python3 lab8_chart.py task4 "$2"
        fi
        ;;
    save-all)
        if [[ "$2" == "--force" ]]; then
            python3 lab8_chart.py save-all --force
        else
            python3 lab8_chart.py save-all
        fi
        ;;
    all)
        echo ""
        echo "============================================="
        echo "  ЗАДАЧА 1: ОТЧЁТ ПО ГРУППАМ И ДИСЦИПЛИНАМ"
        echo "============================================="
        python3 lab8_report_fixed.py task1
        
        echo ""
        echo "============================================="
        echo "  ЗАДАЧА 2: СВОДНАЯ ТАБЛИЦА"
        echo "============================================="
        python3 lab8_report_fixed.py task2
        
        echo ""
        echo "============================================="
        echo "  ЗАДАЧА 3: ГРАФИК ДИНАМИКИ"
        echo "============================================="
        echo "  График откроется в новом окне"
        python3 lab8_chart.py task3
        
        echo ""
        echo "============================================="
        echo "  ЗАДАЧА 4: КРУГОВАЯ ДИАГРАММА"
        echo "============================================="
        echo "  Диаграмма откроется в новом окне"
        python3 lab8_chart.py task4
        ;;
    *)
        show_help
        ;;
esac
